<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvRoomName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room A-101"
                android:textColor="#1E293B"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvRoomCapacity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="30 seats"
                android:textColor="#64748B"
                android:textSize="12sp" />
        </RelativeLayout>

        <TableLayout
            android:id="@+id/tlSeatingTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:stretchColumns="1,2">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F1F5F9"
                android:padding="8dp">
                <TextView android:text="Seat" android:textStyle="bold" android:textSize="11sp" android:paddingEnd="8dp"/>
                <TextView android:text="Name" android:textStyle="bold" android:textSize="11sp"/>
                <TextView android:text="Reg No" android:textStyle="bold" android:textSize="11sp" android:paddingStart="8dp"/>
                <TextView android:text="Date" android:textStyle="bold" android:textSize="11sp" android:paddingStart="8dp"/>
                <TextView android:text="Time" android:textStyle="bold" android:textSize="11sp" android:paddingStart="8dp"/>
            </TableRow>

            <!-- Rows will be added dynamically here -->

        </TableLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>