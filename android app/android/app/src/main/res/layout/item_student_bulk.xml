<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="8dp">

    <CheckBox
        android:id="@+id/cbStudent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/text_grey" />

    <TextView
        android:id="@+id/tvStudentName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:text="Rahul Sharma"
        android:textColor="@color/black"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvRegNo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="CS2021001"
        android:textColor="@color/text_grey"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvBranch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.8"
        android:background="@drawable/bg_branch_badge"
        android:backgroundTint="@color/edittext_bg"
        android:gravity="center"
        android:paddingVertical="2dp"
        android:text="CSE"
        android:textColor="@color/text_grey"
        android:textSize="12sp" />

</LinearLayout>